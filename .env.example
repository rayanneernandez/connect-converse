# Copy this file to `.env.local` and adjust as needed.
# The frontend is fully functional without any of these — they just enable
# optional backend integrations.

# URL of the Libras recognition WebSocket backend (libras-backend/server.py).
# When set, enabling the "Libras" caption option will start streaming frames
# to this endpoint and rendering recognised signs as captions.
# Leave empty / undefined to disable backend-powered Libras → text.
VITE_LIBRAS_WS_URL=ws://localhost:8000/libras
